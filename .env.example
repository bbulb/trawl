# Copy to .env and adjust for your local llama-server setup.
# All variables are optional — trawl ships with sensible defaults
# (pointing at localhost:8081/8082/8083/8080). Only set what you need
# to override.

# ---- Embeddings (required for retrieval) ----
# bge-m3 served by llama-server with --embeddings
TRAWL_EMBED_URL=http://localhost:8081/v1
TRAWL_EMBED_MODEL=bge-m3

# ---- Cross-encoder reranker (optional; falls back to cosine-only) ----
# bge-reranker-v2-m3 served by llama-server with --reranking --pooling rank
TRAWL_RERANK_URL=http://localhost:8083/v1
TRAWL_RERANK_MODEL=bge-reranker-v2-m3
# Include page title + section heading as labelled fields in the
# reranker input (DeepQSE-style). Default on. Set to 0 to restore
# the legacy heading-only format.
# TRAWL_RERANK_INCLUDE_TITLE=1

# ---- HyDE query expansion (optional; off by default) ----
# Small utility LLM (e.g. Gemma 4B)
TRAWL_HYDE_URL=http://localhost:8082/v1
TRAWL_HYDE_MODEL=gemma
# Pin to a specific llama-server slot for KV-cache reuse (optional)
# TRAWL_HYDE_SLOT=1

# ---- VLM page profiling (required only for profile_page) ----
# When unset, the MCP server hides profile_page from its tool list.
TRAWL_VLM_URL=http://localhost:8080/v1
TRAWL_VLM_MODEL=gemma
TRAWL_VLM_TIMEOUT=120
TRAWL_VLM_MAX_TOKENS=2048
# TRAWL_VLM_SLOT=2

# ---- Profile cache locations (optional) ----
# TRAWL_PROFILE_DIR=~/.cache/trawl/profiles
# TRAWL_VISITS_FILE=~/.cache/trawl/visits.json

# ---- Benchmark only (benchmarks/run_benchmark.py) ----
# Get a free key at https://jina.ai/reader/
# JINA_API_KEY=

# ---- Raw passthrough (optional; off by default) ----
# Hard cap on raw-passthrough response size in bytes. When fetch_page
# receives JSON/XML/RSS/Atom, the body is returned as-is (no extraction,
# no chunking, no embedding) up to this many bytes. Default: 262144
# (256 KB ≈ 64K tokens — fits most local LLM context windows).
# TRAWL_PASSTHROUGH_MAX_BYTES=262144

# ---- Telemetry (opt-in; used to inform C4 decision) ----
# Set TRAWL_TELEMETRY=1 to append one JSON line per fetch_relevant() call.
# TRAWL_TELEMETRY=1
# TRAWL_TELEMETRY_PATH=~/.cache/trawl/telemetry.jsonl
# TRAWL_TELEMETRY_MAX_BYTES=67108864

# ---- Per-fetch cache (C8; on by default) ----
# Reuses successful HTML/PDF fetches within TTL so repeated visits skip
# Playwright + Trafilatura. Chunking / embedding / retrieval still run
# per query. Set TTL to 0 to disable entirely.
# TRAWL_FETCH_CACHE_TTL=300
# TRAWL_FETCH_CACHE_PATH=~/.cache/trawl/fetches
# TRAWL_FETCH_CACHE_MAX_MB=100

# ---- Per-host adaptive ceiling (C9; on by default) ----
# Learns each hostname's p95 Playwright fetch duration and adapts the
# content-ready wait ceiling accordingly. After MIN_OBSERVATIONS=5
# observations a host uses p95 * 1.5 clamped to [1500, 15000] ms; new
# hosts fall back to the caller default (5000 ms). Set to 0 to disable.
# TRAWL_HOST_STATS=1
# TRAWL_HOST_STATS_PATH=~/.cache/trawl/host_stats.json
